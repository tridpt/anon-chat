# Copy to .env and adjust as needed. Do not commit your real .env.

# HTTP and Socket.IO port.
PORT=3000

# Directory for durable report and ban records.
DATA_DIR=./data

# Secret that protects the moderation dashboard and API.
# Leave empty to disable admin access. Use a long, random value in production.
ADMIN_TOKEN=

# Optional: enable the Socket.IO Redis adapter for multi-instance deployments.
# Example: redis://localhost:6379
REDIS_URL=
